# ─── Pancake POS ──────────────────────────────────────────────────────────────
# Lấy tại: pos.pancake.vn → Cài đặt → Ứng dụng → API KEY
PANCAKE_API_KEY="your_pancake_api_key_here"

# Lấy tại: URL khi đăng nhập POS, ví dụ pos.pancake.vn/shops/123456 → shop_id = 123456
PANCAKE_SHOP_ID="123456"

# Lấy tại: POS → Sản phẩm → chọn sản phẩm → xem ID trên URL hoặc API
# Nếu sản phẩm không có biến thể, variation_id = product_id
PANCAKE_PRODUCT_ID_COMBO1="prod_id_3lo"
PANCAKE_VARIATION_ID_COMBO1="var_id_3lo"

PANCAKE_PRODUCT_ID_COMBO2="prod_id_6lo"
PANCAKE_VARIATION_ID_COMBO2="var_id_6lo"

PANCAKE_PRODUCT_ID_COMBO3="prod_id_9lo"
PANCAKE_VARIATION_ID_COMBO3="var_id_9lo"

# Lấy tại: POS → Kho hàng → xem ID
PANCAKE_WAREHOUSE_ID="warehouse_id_here"

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Tạo bot: nhắn @BotFather trên Telegram → /newbot
TELEGRAM_BOT_TOKEN="123456789:AABBCCDDEEFFaabbccddeeff-xxxxxxxxxxxxxxx"

# Chat ID nhận thông báo:
# - Cá nhân: nhắn @userinfobot → lấy "Id"
# - Nhóm: thêm bot vào nhóm → nhắn @userinfobot trong nhóm → lấy "Id" (số âm)
TELEGRAM_CHAT_ID="-100xxxxxxxxxx"
